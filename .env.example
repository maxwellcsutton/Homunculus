# ─────────────────────────────────────────────────────────────────────────────
# homunculus — configuration. Copy to `.env` and fill in. Everything is local-native.
# Naming: AGENT_* = app/agent behavior · MODEL_*/LLAMA_* = the text model + serving ·
# VISION_* = the image lane. See docs/MODEL_SERVING.md and docs/ARCHITECTURE.md.
# ─────────────────────────────────────────────────────────────────────────────

# ── Database (local Postgres — the identity store, the irreplaceable part) ──────────────
DATABASE_URL="postgresql://localhost:5432/homunculus?schema=public"

# ── The agent ───────────────────────────────────────────────────────────────────────────
# Display name for the human the agent talks to (used in chat framing). Default: "the user".
AGENT_OWNER_NAME="the user"
# Heartbeat cadence (ms). There's ONE CLOCK PER LANE: the chat/self heartbeat (triage → reflect/reach-out)
# and the game heartbeat (the agent's voluntary-play clock). AGENT_HEARTBEAT_MS is the shared default for
# both; set the per-lane vars to tune each independently (e.g. a fast game tick for an idle game, a slower
# self tick). The game heartbeat only runs when the game supports voluntary sessions (GAME_OPEN_URL).
# Cadence is plumbing only; WHAT the agent does each tick is its own choice (see CLAUDE.md, docs/LANES.md).
AGENT_HEARTBEAT_MS=60000
AGENT_CHAT_HEARTBEAT_MS=
AGENT_GAME_HEARTBEAT_MS=
# Warm-base rebake cadence (ms) — re-merge the day's identity edits into a fresh frozen base.
# Tradeoff: longer = fewer cold re-prefills, larger per-turn diff. Default 1h.
AGENT_REBAKE_MS=3600000
# Rolling chat history window (turns) fed into a chat tick.
AGENT_HISTORY_MAX=10

# ── Proactive outreach (DEFAULT OFF — feature-flagged) ──────────────────────────────────
# When off, the agent never messages the user unprompted; it still answers when messaged.
AGENT_PROACTIVE_ENABLED=0
# Quiet hours + soft cooldown for unprompted reach-outs (only apply when proactive is on).
AGENT_ACTIVE_START=8
AGENT_ACTIVE_END=23
AGENT_REACHOUT_COOLDOWN_MS=5400000

# ── Text model — the chat lane (the required base lane) ──────────────────────────────────
# An OpenAI-compatible /v1 chat-completions endpoint (llama.cpp llama-server). The app never
# manages thinking; reasoning depth is bounded server-side via --reasoning-budget (serveModel.ts).
# This is the REQUIRED base lane; the game lane (below) is optional and falls back to it.
MODEL_BASE_URL="http://127.0.0.1:8080/v1"
MODEL_NAME="qwen3.6"
MODEL_TEMPERATURE=0.6
MODEL_TOP_P=0.92
MODEL_TOP_K=40
MODEL_MAX_TOKENS=5120
# Game build passes reason a lot; optional wider total budget for them only (unset → use default).
MODEL_MAX_TOKENS_GAME=

# ── Game lane (the primary work lane — optional second instance) ──────────────────────────
# The agent's primary work is PLAYING, so the game lane carries game passes + ALL idle cognition
# (heartbeats, reflect, game-engage, rebake). A SECOND llama-server instance here means a long game
# pass never evicts the chat lane's warm KV cache, and each lane stays warm independently. UNSET →
# the game lane falls back to the chat lane (single instance; fully serialized). When/why to run two:
# docs/LANES.md. (See docs/MODEL_SERVING.md "lanes" for the serving flags.)
MODEL_BASE_URL_GAME=
MODEL_TEMPERATURE_GAME=0.45
# Parallel llama.cpp slots, if you run a single multi-slot server instead of separate instances.
# Leave 1 unless you know why (a single multi-slot server scatters chat across cold slots).
AGENT_MODEL_SLOTS=1

# ── Embedding lane (optional — semantic de-duplication of the agent's messages) ──────────
# Point at a side llama-server launched with --embeddings. Unset → de-dup is lexical-only.
AGENT_EMBED_URL=
AGENT_EMBED_MODEL=embed
AGENT_SEMANTIC_DEDUP_THRESHOLD=0.80

# ── Vision lane (optional — image → text captioning) ────────────────────────────────────
# A separate multimodal llama-server (Qwen3-VL + mmproj). Unset → attachments aren't described.
VISION_BASE_URL=
VISION_MODEL=qwen3-vl
VISION_MAX_TOKENS=256
VISION_MAX_IMAGES=4

# ── Game integration (the abstract adapter) ─────────────────────────────────────────────
# Where the agent reaches the game backend's tool-exec callback, if a game is wired. The game
# implements the GameAdapter contract (src/game/adapter.ts). UNSET → game lane is dormant.
GAME_EXEC_URL=
GAME_CATALOG_URL=
# Optional bearer token the agent presents to the game (and the game presents to the agent).
GAME_AI_EXEC_TOKEN=

# ── Per-caller auth (optional; set in deployment) ───────────────────────────────────────
# When set, the matching API routes require `Authorization: Bearer <token>`. Unset → dev-open.
AGENT_CHAT_TOKEN=
AGENT_GAME_TOKEN=

# ── llama.cpp serving (scripts/serveModel.ts) — machine-specific paths + tuned flags ─────
LLAMA_SERVER_BIN="/opt/homebrew/bin/llama-server"
LLAMA_MODEL_PATH="/path/to/your/model.gguf"
LLAMA_PORT=8080
LLAMA_CTX=131072
# Reasoning: force a bounded <think> block so the model emits clean tool_calls (see serveModel.ts).
LLAMA_REASONING=on
LLAMA_REASONING_BUDGET=2048
LLAMA_REASONING_BUDGET_GAME=2048
# Anti-loop levers (chat lane). DRY = sequence-level repeat penalty; the real fix for verbatim loops.
LLAMA_DRY_MULTIPLIER=0.8
LLAMA_FREQUENCY_PENALTY=0.25
# Sampler order (empty = stock). For Qwen reasoning models, moving temperature ahead of penalties/dry
# fixes "endless generation". To A/B: LLAMA_SAMPLERS="top_k;top_p;min_p;temperature;dry;penalties"
LLAMA_SAMPLERS=

# Embed server (scripts/serveEmbed.ts)
LLAMA_EMBED_MODEL_PATH="/path/to/embed-model.gguf"
LLAMA_EMBED_PORT=8082

# Vision server (scripts/serveVision.ts)
VISION_MODEL_PATH="/path/to/vl-model.gguf"
VISION_MMPROJ_PATH="/path/to/mmproj.gguf"
LLAMA_VISION_PORT=8083

# ── Backups (scripts/backup.ts) ─────────────────────────────────────────────────────────
BACKUP_DIR="./backups"
# age public key for encrypting offsite dumps; rclone remote for the push. Optional.
AGE_RECIPIENT=
RCLONE_REMOTE=
